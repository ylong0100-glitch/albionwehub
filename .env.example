# AlbionHub Environment Variables

# No secrets needed for MVP - all APIs are public
# These are optional overrides

# Override AODP base URLs (defaults built into code)
# AODP_WEST_URL=https://west.albion-online-data.com
# AODP_EAST_URL=https://east.albion-online-data.com
# AODP_EUROPE_URL=https://europe.albion-online-data.com

# Override SBI Gameinfo API base URLs
# GAMEINFO_AMERICAS_URL=https://gameinfo.albiononline.com/api/gameinfo
# GAMEINFO_ASIA_URL=https://gameinfo-sgp.albiononline.com/api/gameinfo
# GAMEINFO_EUROPE_URL=https://gameinfo-ams.albiononline.com/api/gameinfo
